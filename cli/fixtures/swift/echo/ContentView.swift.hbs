import SwiftUI

struct ContentView: View {
    @StateObject private var actrService = ActrService()
    @State private var statusMessage = ""
    @State private var alertMessage: String?
    @State private var isInitialized = false

    var body: some View {
        NavigationView {
            VStack(spacing: 16) {
                Text("{{PROJECT_NAME_PASCAL}}")
                    .font(.largeTitle.weight(.bold))

                Text("Status: \(actrService.connectionStatus.description)")
                    .font(.subheadline)
                    .foregroundColor(statusColor)

                Button(action: initializeActrService) {
                    Text(actrService.connectionStatus == .connected ? "Connected" : "Initialize")
                        .frame(maxWidth: .infinity)
                        .padding(.vertical, 10)
                        .background(actrService.connectionStatus == .connected ? Color.green : Color.blue)
                        .foregroundColor(.white)
                        .cornerRadius(8)
                }
                .disabled(actrService.connectionStatus == .connected || actrService.connectionStatus == .initializing)

                if !statusMessage.isEmpty {
                    Text(statusMessage)
                        .frame(maxWidth: .infinity, alignment: .leading)
                        .padding()
                        .background(Color.gray.opacity(0.15))
                        .cornerRadius(8)
                }

                Spacer()
            }
            .padding()
            #if os(iOS)
            .navigationBarTitleDisplayMode(.inline)
            #endif
        }
        .onAppear {
            guard !isInitialized else { return }
            initializeActrService()
        }
        .alert("Error", isPresented: Binding(
            get: { alertMessage != nil },
            set: { if !$0 { alertMessage = nil } }
        )) {
            Button("OK") {
                alertMessage = nil
            }
        } message: {
            Text(alertMessage ?? "Unknown error")
        }
    }

    private var statusColor: Color {
        switch actrService.connectionStatus {
        case .disconnected:
            return Color.gray
        case .initializing:
            return Color.orange
        case .connected:
            return Color.green
        case .error:
            return Color.red
        }
    }

    private func initializeActrService() {
        Task {
            do {
                try await actrService.initializeFromBundle()
                isInitialized = true
                statusMessage = "Connected"
            } catch {
                alertMessage = "Initialization failed: \(error.localizedDescription)"
                statusMessage = "Initialization failed"
            }
        }
    }
}

