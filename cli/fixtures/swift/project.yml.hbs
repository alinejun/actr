name: {{PROJECT_NAME_PASCAL}}
options:
  bundleIdPrefix: io.actrium

packages:
  actr-swift:
{{#if ACTR_LOCAL_PATH}}
    path: {{{ACTR_LOCAL_PATH}}}
{{else}}
    url: https://github.com/Actrium/actr-swift-package-sync
    from: {{ACTR_SWIFT_VERSION}}
{{/if}}
  swift-protobuf:
    url: https://github.com/apple/swift-protobuf.git
    exactVersion: 1.32.0

targets:
  {{PROJECT_NAME_PASCAL}}:
    type: application
    platform: iOS
    deploymentTarget: "15.0"
    sources:
      - path: {{PROJECT_NAME_PASCAL}}
      - path: manifest.toml
        type: file
        buildPhase: resources
      - path: actr.toml
        type: file
        buildPhase: resources
      # IMPORTANT: manifest.lock.toml must be included as a resource
      #
      # Why this is necessary:
      # - The lock file contains actr_type metadata for dependencies
      # - This metadata is needed at runtime for service discovery and type matching
      # - Code generation reads this file to map proto files to actr_types
      #
      # Note: An empty lock file is generated during `actr init` to satisfy
      # xcodegen's requirement that all referenced files must exist.
      # The file is populated with actual dependencies by `actr deps install`.
      - path: manifest.lock.toml
        type: file
        buildPhase: resources
    settings:
      PRODUCT_BUNDLE_IDENTIFIER: io.actrium.{{PROJECT_NAME_PASCAL}}
      INFOPLIST_FILE: {{PROJECT_NAME_PASCAL}}/Info.plist
      MARKETING_VERSION: 1.0.0
      CURRENT_PROJECT_VERSION: 1
      ENABLE_PREVIEWS: YES
      SWIFT_VERSION: 6.0
      ASSETCATALOG_COMPILER_APPICON_NAME: AppIcon
      GENERATE_INFOPLIST_FILE: NO
      SUPPORTS_MAC_DESIGNED_FOR_IPAD: YES

    dependencies:
      - package: actr-swift
        product: Actr
      - package: swift-protobuf
        product: SwiftProtobuf
