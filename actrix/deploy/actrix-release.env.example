# Actrix manual release pull — server configuration.
#
# Copy to /etc/actrix/release.env and edit. The install directory is NOT set
# here; it is decided by the current directory or --install-dir at run time.
#
# File mode should be 0600 if GITHUB_TOKEN is populated:
#   sudo install -m 0600 actrix-release.env.example /etc/actrix/release.env

# GitHub owner/repo that hosts the Actrix Release Train releases.
ACTRIX_REPOSITORY=Actrium/actr

# systemd unit name (without the .service suffix).
ACTRIX_SERVICE_NAME=actrix-managed

# Seconds to wait for the service to become active after restart before
# rolling back to the previous version.
ACTRIX_HEALTH_WAIT_SECONDS=3

# Default config file passed to actrix via --config. Override per-run with
# --config <path>. Default if unset: /etc/actrix/config.toml
# ACTRIX_CONFIG_PATH=/etc/actrix/config.toml

# Default systemd WorkingDirectory (where actrix resolves relative config
# paths such as sqlite_path / cert / log dir). Defaults to the dirname of
# the config file when unset.
# ACTRIX_WORKING_DIR=/opt/actrix

# Only required for private repositories. Needs Contents: Read scope.
# Permissions 0600 strongly recommended when set.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
