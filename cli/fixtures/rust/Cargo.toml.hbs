[package]
name = "{{PROJECT_NAME}}"
version = "0.1.0"
edition = "2024"

[lib]
name = "{{PROJECT_NAME_SNAKE}}_guest"
crate-type = ["cdylib", "rlib"]

[[bin]]
name = "{{PROJECT_NAME}}"
path = "src/main.rs"

[dependencies]
actr-config = "0.3"
actr-framework = "0.3"
actr-hyper = { version = "0.3", features = ["wasm-engine"] }
actr-protocol = "0.3"
async-trait = "0.1"
anyhow = "1"
base64 = "0.22"
bytes = "1"
prost = "0.14"
prost-types = "0.14"
serde_json = "1"
tokio = { version = "1", features = ["full"] }
tracing = "0.1"
