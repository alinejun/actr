edition = 1
exports = ["protos/local/local.proto"]

[package]
name = "{{PROJECT_NAME_PASCAL}}"
manufacturer = "{{MANUFACTURER}}"
version = "1.0.0"
description = "Empty Actor-RTC workload package"
authors = []
license = "Apache-2.0"
tags = ["dev", "service"]

[binary]
path = "dist/{{PROJECT_NAME_SNAKE}}.cdylib"

[build]
tool = "cargo"
manifest_path = "Cargo.toml"
artifact = "lib"
profile = "release"
features = ["cdylib"]
post_build = [
  'mkdir -p "$(dirname "$ACTR_BUILD_BINARY_PATH")" && TARGET_ROOT="${CARGO_TARGET_DIR:-target}" && case "$(uname)" in Darwin) LIB_NAME="lib{{PROJECT_NAME_SNAKE}}.dylib" ;; Linux) LIB_NAME="lib{{PROJECT_NAME_SNAKE}}.so" ;; *) LIB_NAME="{{PROJECT_NAME_SNAKE}}.dll" ;; esac && for SRC in "$TARGET_ROOT/$ACTR_BUILD_TARGET/$ACTR_BUILD_PROFILE/$LIB_NAME" "$TARGET_ROOT/$ACTR_BUILD_PROFILE/$LIB_NAME"; do if [ -f "$SRC" ]; then cp "$SRC" "$ACTR_BUILD_BINARY_PATH"; exit 0; fi; done && echo "Unable to locate built workload library under $TARGET_ROOT" >&2 && exit 1',
]
